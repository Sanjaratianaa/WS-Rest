{
  "info": {
    "name": "Transport API",
    "description": "Collection complète pour tester l'API Transport avec JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "employeToken", "value": "" }
  ],
  "item": [
    {
      "name": "Authentification",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.test('Login admin OK', function() { pm.response.to.have.status(200); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@transport.com\",\n  \"motDePasse\": \"Admin@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Employe (Jean)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('employeToken', json.token);",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.test('Login employe OK', function() { pm.response.to.have.status(200); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean@transport.com\",\n  \"motDePasse\": \"Emp@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Register Nouvel Employe",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register OK', function() { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Razafy\",\n  \"prenom\": \"Luc\",\n  \"email\": \"luc@transport.com\",\n  \"motDePasse\": \"Luc@1234\",\n  \"confirmationMotDePasse\": \"Luc@1234\",\n  \"telephone\": \"0341234567\",\n  \"idDepartement\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login SANS credentials (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Doit retourner 400/401', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 401]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fake@transport.com\",\n  \"motDePasse\": \"wrong\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
